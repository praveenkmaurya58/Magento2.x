<?xml version="1.0"?>
<!--
    Layout file to override the admin login page template for Vendor_CreateAdmin module
--> 
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="admin.login">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Vendor_CreateAdmin::admin/login.phtml</argument>
            </action>
        </referenceBlock>
    </body>
</page>
